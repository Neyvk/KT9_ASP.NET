@model IEnumerable<KT9_ASP.NET.Models.ApplicationUser>

<h2>Users</h2>

<a asp-action="Create" class="btn btn-primary mb-3">
    Add User
</a>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Email</th>
            <th></th>
        </tr>
    </thead>

    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.FullName</td>
                <td>@user.Email</td>

                <td>
                    <a asp-action="Edit" asp-route-id="@user.Id"
                       class="btn btn-warning">
                        Edit
                    </a>

                    <a asp-action="Delete" asp-route-id="@user.Id"
                       class="btn btn-danger">
                        Delete
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>